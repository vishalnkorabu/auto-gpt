LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional fallback provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Optional: web search providers (set one)
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Local embedding model for FAISS memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: number of sources to collect
MAX_WEB_RESULTS=6
MAX_PAPER_RESULTS=4
MAX_PLANNED_QUERIES=4
